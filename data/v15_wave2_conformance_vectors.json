    {"id": "budget_04_cumulative", "ops": [
      {"action": "check_post", "input": 100, "output": 50, "budget": 1000},
      {"action": "check_post", "input": 100, "output": 50, "budget": 1000},
      {"expected_consumed": 300}
    ]},
    {"id": "budget_05_mandate_reset", "invariant": "mandate revision resets budget counter for that mandate only"},
    {"id": "budget_06_policy_no_reset", "invariant": "policy change does NOT reset budget counters"},
    {"id": "budget_07_metadata_shape", "required_fields": ["budget_status", "budget_tokens_authorized", "tokens_consumed_this_call", "tokens_consumed_cumulative", "budget_remaining"]}
  ]
