    {"id": "route_02_full", "mandate": {"routing_tier": "full"}, "expected_routed_to": "full"},
    {"id": "route_03_default", "mandate": {}, "expected_routed_to": "full"},
    {"id": "route_04_invalid", "mandate": {"routing_tier": "turbo"}, "expected_routed_to": "full"},
    {"id": "route_05_null_mandate", "mandate": null, "expected_routed_to": "full"}
  ],

  "budget_enforcement_vectors": [
    {"id": "budget_01_within", "budget": 1000, "input_tokens": 100, "expected_status": "ok_pre"},
    {"id": "budget_02_exceeded_pre", "budget": 100, "input_tokens": 500, "expected_status": "exceeded_pre"},
    {"id": "budget_03_exceeded_post", "ops": [
      {"action": "check_post", "input": 400, "output": 400, "budget": 500},
      {"action": "check_post", "input": 200, "output": 200, "budget": 500, "expected_status": "exceeded_post"}
